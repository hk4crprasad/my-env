# ─────────────────────────────────────────────────────────────────
#  Email Triage Environment — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your actual .env to git.
# ─────────────────────────────────────────────────────────────────


# ── LLM / Inference ───────────────────────────────────────────────

# API endpoint for LLM calls (required for inference.py)
# HuggingFace router:  https://router.huggingface.co/v1
# OpenAI:              https://api.openai.com/v1
API_BASE_URL=https://router.huggingface.co/v1

# Your HuggingFace token or OpenAI API key (required for inference.py)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative key name (either HF_TOKEN or API_KEY works)
# API_KEY=your-api-key-here

# Model identifier to use for inference
# HuggingFace router options:
#   openai/gpt-oss-120b        (default — no token needed via HF router)
#   meta-llama/Llama-3.3-70B-Instruct
#   Qwen/Qwen2.5-72B-Instruct
MODEL_NAME=openai/gpt-oss-120b

# ── Trained adapter (local inference mode) ────────────────────────────

# Set to 1 to load the fine-tuned LoRA adapter instead of hitting the API
# Requires: pip install transformers peft accelerate
USE_LOCAL_MODEL=0

# The trained LoRA adapter (uploaded after GRPO training)
ADAPTER_MODEL_ID=Hk4crprasad/email-triage-grpo

# Base model the adapter was trained on
BASE_MODEL_ID=Qwen/Qwen2.5-3B-Instruct


# ── MongoDB ───────────────────────────────────────────────────────

# MongoDB connection string
# Local:        mongodb://localhost:27017
# Atlas (prod): mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
MONGODB_URL=mongodb://localhost:27017

# MongoDB database name (default: email_triage)
MONGODB_DB=email_triage


# ── Server ────────────────────────────────────────────────────────

# Port for the FastAPI server (HuggingFace Spaces uses 7860)
PORT=7860
